# Copy to repository root as .env, then edit.
#
# Required DNS:
# - RMM_DOMAIN points to this server
# - HEADSCALE_DOMAIN points to this server
#
# Required inbound ports:
# - TCP 80 and 443 for Caddy/HTTPS
# - UDP 3478 for Headscale STUN/DERP assistance

RMM_DOMAIN=rmm.example.com
HEADSCALE_DOMAIN=headscale.example.com

POSTGRES_PASSWORD=change-me-long-random-password

# Generate with: make deploy-bootstrap-token
RMM_BOOTSTRAP_TOKEN=

# Generate after first deploy-up with: make deploy-headscale-key
RMM_HEADSCALE_API_KEY=

RMM_API_ADDR=:8080
RMM_AUTO_MIGRATE=true
RMM_MIGRATIONS_DIR=/migrations
RMM_PUBLIC_BASE_URL=https://rmm.example.com

# Endpoint SSH command execution.
# deploy-render generates deploy/generated/ssh/id_ed25519(.pub) automatically.
RMM_SSH_USER=rmm
RMM_SSH_PORT=22
